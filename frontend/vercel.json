{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "env": {
    "VITE_API_BASE": {
      "description": "Base URL of the deployed backend API (no trailing slash).",
      "value": "https://voice-shopping-api.onrender.com"
    }
  }
}
